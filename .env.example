GROQ_API_KEY=
ELEVENLABS_API_KEY=
NEXT_PUBLIC_ELEVENLABS_VOICE_ID=

# Optional Firecrawl (https://firecrawl.dev/) API key — server-side only. Enables v2 scrape in /api/browse and the veil__browse_page built-in; without it VEIL strips HTML with a plain fetch.
FIRECRAWL_API_KEY=

# MCP (Model Context Protocol) HTTP endpoints — VEIL merges these and lists every tool across all servers.

# Prefer underscore keys. If you still use NEXT_PUBLIC_MCP_ENDPOINT_YT-VIDEO it is supported via bracket lookups in lib/mcp-endpoints.ts — but hyphen names often break tooling and must not use process.env.<NAME> with minus in TS.
NEXT_PUBLIC_MCP_ENDPOINT_YOUTUBE_VIDEO=https://still-thunder-8btdl.run.mcp-use.com/mcp

NEXT_PUBLIC_MCP_ENDPOINT_MUSIC=https://young-surf-xt5j8.run.mcp-use.com/mcp

NEXT_PUBLIC_MCP_ENDPOINT_MESSAGE=https://summer-poetry-bwin6.run.mcp-use.com/mcp

# Handle passed to messaging MCP register / read-inbox / send-message. Use the real agent handle (e.g. veil), NOT the literal name of this env var.
NEXT_PUBLIC_VEIL_RELAY_AGENT_NAME=veil

# Optional HTTPS gallery listing for outbound links in the crew deck modal (recommended).
NEXT_PUBLIC_ONE_PIECE_GALLERY_URL=

# Legacy alias — read if NEXT_PUBLIC_ONE_PIECE_GALLERY_URL is empty.
NEXT_PUBLIC_ONE_PIECE_COLLECTION_URL=

# Optional HTTPS link displayed as “sprite import docs”.
# NEXT_PUBLIC_SPRITE_IMPORT_DOCS_URL=

# Colony pet theme: leave empty for office sprites (dwight / vault-boy / friday), or `onepiece` for crew slugs in lib/one-piece-collection.ts.
# One Piece folders under public/assets/pets/<slug>/ ship with a temporary spritesheet copy so animation works; replace each spritesheet.webp with your own Codex-format art when ready.
NEXT_PUBLIC_COLONY_PET_THEME=

# Optional legacy aliases (merged with semantic endpoints above).
# NEXT_PUBLIC_MCP_ENDPOINT_1=
# NEXT_PUBLIC_MCP_ENDPOINT_2=
